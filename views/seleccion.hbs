<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Selecciona una ciudad - WeatherNow</title>
  <link rel="stylesheet" href="/css/seleccionStyle.css">
</head>
<body>

  <!-- HEADER -->
  <header class="header">
    <h1>🌤 WeatherNow</h1>
    <nav>
      <a href="/">Inicio</a>
      <a href="/historial">Historial</a>
    </nav>
  </header>

  <!-- Contenido -->
  <main class="container">

    <!-- Selección de ciudades -->
    <section class="selection-section">
      <h2>Selecciona la ciudad correcta</h2>
      <p>Se encontraron varias coincidencias, elige la que deseas:</p>

      <div class="selection-grid">
        {{#each lugares}}
        <div class="selection-card">
          <h3>{{lugar}}</h3>
          <p>Latitud: {{lat}} | Longitud: {{lon}}</p>
        <form action="/clima" method="GET">

  <!-- Se envia ciudadFull para indicar la selección exacta que decidió el usuario -->
  <input type="hidden" name="ciudadFull" value="{{lugar}},{{pais}}">
  <button type="submit">Seleccionar</button>
</form>

        </div>
        {{/each}}
      </div>

      <a href="/" class="back-link">Volver al inicio</a>
    </section>

  </main>

  <!-- FOOTER -->
  <footer class="footer">
    <p>Elaborado por <strong>Mariana Dehesa Cabrera</strong> – Aplicación Web del Clima 🌤</p>
  </footer>

</body>
</html>
